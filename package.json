{
  "name": "@criipto/verify-react",
  "private": false,
  "version": "4.1.4",
  "type": "module",
  "description": "Verify SDK for React Single Page Applications",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./index.css": {
      "import": "./dist/index.css"
    }
  },
  "scripts": {
    "test": "vitest --environment jsdom",
    "build": "tsdown --config tsdown.config.ts",
    "dev": "npm run build -- --watch",
    "check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "npm run check && npm run clean && npm run build",
    "prepare": "husky"
  },
  "peerDependencies": {
    "react": "^16.11.0 || ^17 || ^18 || ^19",
    "react-dom": "^16.11.0 || ^17 || ^18 || ^19"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^3.2.4",
    "@storybook/addon-actions": "^8.5.3",
    "@storybook/addon-essentials": "^8.5.3",
    "@storybook/addon-interactions": "^8.5.3",
    "@storybook/addon-links": "^8.5.3",
    "@storybook/addon-onboarding": "^8.5.3",
    "@storybook/addon-webpack5-compiler-babel": "^3.0.5",
    "@storybook/addon-webpack5-compiler-swc": "^2.0.0",
    "@storybook/blocks": "^8.5.3",
    "@storybook/react": "^8.5.3",
    "@storybook/react-webpack5": "^8.5.3",
    "@storybook/test": "^8.5.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsdown/css": "^0.21.4",
    "@types/qrcode": "^1.4.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ua-parser-js": "^0.7.36",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^16.2.6",
    "msw": "^2.12.10",
    "prettier": "^3.6.2",
    "publint": "^0.3.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.5.3",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/criipto/criipto-verify-react.git"
  },
  "keywords": [
    "criipto",
    "verify",
    "mitid",
    "bankid",
    "react"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/criipto/criipto-verify-react/issues"
  },
  "homepage": "https://github.com/criipto/criipto-verify-react#readme",
  "dependencies": {
    "@criipto/auth-js": "^3.7.2",
    "jwt-decode": "^3.1.2",
    "qrcode": "^1.5.4",
    "ua-parser-js": "^1.0.37"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  }
}
