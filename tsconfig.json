{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "es6",
    "jsx": "react-jsx",
    "module": "es2015",
    "moduleResolution": "bundler",
    "isolatedModules": true,
    "strict": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["src/**/*.stories.*"]
}
